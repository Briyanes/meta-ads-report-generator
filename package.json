{
  "name": "meta-ads-report-generator",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "postinstall": "cp -r node_modules/bootstrap-icons/font/fonts public/fonts 2>/dev/null || true",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:reset": "bash scripts/dev-reset.sh",
    "automate:rmoda": "playwright test --config=app/playwright.config.ts e2e/rmoda-workshop-ctwa.spec.ts --headed",
    "automate:rmoda:headless": "playwright test --config=app/playwright.config.ts e2e/rmoda-workshop-ctwa.spec.ts",
    "automate:all": "playwright test --config=app/playwright.config.ts e2e/generate-all-objectives.spec.ts --headed",
    "automate:all:headless": "playwright test --config=app/playwright.config.ts e2e/generate-all-objectives.spec.ts",
    "test:playwright": "playwright test --config=app/playwright.config.ts",
    "test:playwright:debug": "playwright test --config=app/playwright.config.ts --debug",
    "test:playwright:ui": "playwright test --config=app/playwright.config.ts --ui"
  },
  "dependencies": {
    "bootstrap-icons": "^1.13.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "next": "14.2.35",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.14.10",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
